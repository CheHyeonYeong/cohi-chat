### Booking File API 시나리오 (S3)

### 변수 설정
@baseUrl = http://localhost:8080/api
# accessToken은 member.http에서 로그인 후 설정됨
# bookingId는 booking.http에서 설정됨

### 1. 파일 업로드
POST {{baseUrl}}/bookings/{{bookingId}}/files
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="file"; filename="test-document.pdf"
Content-Type: application/pdf

< ./test-files/test-document.pdf
------WebKitFormBoundary--

> {%
  client.global.set("fileId", response.body.id);
%}

### 2. 파일 목록 조회
GET {{baseUrl}}/bookings/{{bookingId}}/files
Authorization: Bearer {{accessToken}}

### 3. 파일 다운로드
GET {{baseUrl}}/bookings/{{bookingId}}/files/{{fileId}}/download
Authorization: Bearer {{accessToken}}

### 4. 파일 삭제
DELETE {{baseUrl}}/bookings/{{bookingId}}/files/{{fileId}}
Authorization: Bearer {{accessToken}}

###############################################
# Pre-signed URL API (클라이언트 직접 업로드/다운로드)
###############################################

### 5. Pre-signed 업로드 URL 생성
# 클라이언트가 S3에 직접 파일을 업로드할 수 있는 URL 생성
POST {{baseUrl}}/bookings/{{bookingId}}/files/presigned-upload-url
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fileName": "document.pdf",
  "contentType": "application/pdf"
}

> {%
  client.global.set("presignedUploadUrl", response.body.data.url);
  client.global.set("objectKey", response.body.data.objectKey);
%}

### 6. Pre-signed URL로 S3에 직접 업로드 (curl 사용 예시)
# curl -X PUT "{{presignedUploadUrl}}" -H "Content-Type: application/pdf" --data-binary @./test-files/test-document.pdf

### 7. 업로드 완료 후 DB 등록
POST {{baseUrl}}/bookings/{{bookingId}}/files/confirm-upload
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "objectKey": "{{objectKey}}",
  "originalFileName": "document.pdf",
  "contentType": "application/pdf",
  "fileSize": 123456
}

> {%
  client.global.set("fileId", response.body.data.id);
%}

### 8. Pre-signed 다운로드 URL 생성
# 클라이언트가 S3에서 직접 파일을 다운로드할 수 있는 URL 생성
GET {{baseUrl}}/bookings/{{bookingId}}/files/{{fileId}}/presigned-download-url
Authorization: Bearer {{accessToken}}

> {%
  client.global.set("presignedDownloadUrl", response.body.data.url);
%}

### 9. Pre-signed URL로 S3에서 직접 다운로드 (브라우저에서 URL 접속)
# {{presignedDownloadUrl}}
