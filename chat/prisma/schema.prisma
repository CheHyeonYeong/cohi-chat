generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Canonical shared chat schema for Nest branches.
/// Spring room provisioning and Nest runtime APIs must follow this contract.
model Member {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String    @unique @db.VarChar(50)
  displayName     String    @map("display_name") @db.VarChar(50)
  role            String    @db.VarChar(20)
  isDeleted       Boolean   @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  isBanned        Boolean   @map("is_banned")
  profileImageUrl String?   @map("profile_image_url") @db.VarChar(500)
  roomMembers     RoomMember[]
  sentMessages    Message[]  @relation("MessageSender")

  @@map("member")
}

model ChatRoom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String    @db.VarChar(20)
  status          String    @default("ACTIVE") @db.VarChar(20)
  externalRefType String?   @map("external_ref_type") @db.VarChar(50)
  externalRefId   String?   @map("external_ref_id") @db.Uuid
  isDisabled      Boolean   @default(false) @map("is_disabled")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  members         RoomMember[]
  messages        Message[]

  @@unique([externalRefType, externalRefId], map: "uq_chat_room_external_ref")
  @@index([externalRefType, externalRefId, deletedAt], map: "idx_chat_room_external_ref_deleted_at")
  @@map("chat_room")
}

model RoomMember {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId            String    @map("room_id") @db.Uuid
  memberId          String    @map("member_id") @db.Uuid
  lastReadMessageId String?   @map("last_read_message_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)
  room              ChatRoom  @relation(fields: [roomId], references: [id])
  member            Member    @relation(fields: [memberId], references: [id])
  lastReadMessage   Message?  @relation("RoomMemberLastReadMessage", fields: [lastReadMessageId], references: [id])

  @@unique([roomId, memberId], map: "uq_room_member")
  @@index([memberId, deletedAt], map: "idx_room_member_member_id_deleted_at")
  @@index([roomId], map: "idx_room_member_room_id")
  @@map("room_member")
}

model Message {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String    @map("room_id") @db.Uuid
  senderId    String?   @map("sender_id") @db.Uuid
  messageType String    @map("message_type") @db.VarChar(30)
  content     String?   @db.VarChar(2000)
  payload     Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Global unique message cursor shared across every room.
  cursorSeq   BigInt    @default(autoincrement()) @unique(map: "uq_message_cursor_seq") @map("cursor_seq")
  room        ChatRoom  @relation(fields: [roomId], references: [id])
  sender      Member?   @relation("MessageSender", fields: [senderId], references: [id])
  lastReadBy  RoomMember[] @relation("RoomMemberLastReadMessage")

  @@index([roomId, createdAt(sort: Desc)], map: "idx_message_room_id_created_at")
  @@index([roomId, cursorSeq(sort: Desc)], map: "idx_message_room_id_cursor_seq")
  @@map("message")
}
